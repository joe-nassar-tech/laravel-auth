{
  "name": "joe-404/laravel-auth",
  "description": "Drop-in, config-driven authentication library for Laravel 12 and 13. Registration with OTP + magic-link email verification, login, refresh token rotation, password reset, multi-session management, device fingerprinting, Google OAuth, long-lived API tokens, account status workflow, and referral codes with anti-abuse detection — all through a single JSON API.",
  "keywords": [
    "laravel",
    "laravel-auth",
    "authentication",
    "auth",
    "otp",
    "magic-link",
    "email-verification",
    "sanctum",
    "oauth",
    "google-oauth",
    "socialite",
    "api-token",
    "refresh-token",
    "session-management",
    "device-fingerprinting",
    "rate-limiting",
    "account-lockout",
    "account-management",
    "referral-codes",
    "reverb",
    "laravel-package",
    "spa-authentication",
    "mobile-api",
    "php"
  ],
  "type": "library",
  "license": "MIT",
  "homepage": "https://github.com/joe-nassar-tech/laravel-auth",
  "authors": [
    {
      "name": "Joe Nassar",
      "email": "joe.nassar.tech@gmail.com",
      "homepage": "https://github.com/joe-nassar-tech",
      "role": "Developer"
    }
  ],
  "support": {
    "issues": "https://github.com/joe-nassar-tech/laravel-auth/issues",
    "source": "https://github.com/joe-nassar-tech/laravel-auth"
  },
  "require": {
    "php": "^8.2",
    "laravel/framework": "^12.0|^13.0",
    "laravel/sanctum": "^4.0",
    "laravel/socialite": "^5.0",
    "spatie/laravel-permission": "^6.0",
    "jenssegers/agent": "^2.6"
  },
  "require-dev": {
    "orchestra/testbench": "^10.0",
    "pestphp/pest": "^3.0",
    "pestphp/pest-plugin-laravel": "^3.0"
  },
  "scripts": {
    "test": "vendor/bin/pest"
  },
  "autoload": {
    "psr-4": {
      "Joe404\\LaravelAuth\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Joe404\\LaravelAuth\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Joe404\\LaravelAuth\\AuthServiceProvider"
      ]
    }
  },
  "archive": {
    "exclude": [
      "docs",
      "tests",
      "*.postman_collection.json"
    ]
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
